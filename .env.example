# Tank Game Server Configuration
# Copy this to .env and fill in your actual values

# ==================== SECURITY ====================
# CRITICAL: Use a strong, random secret in production
# Generate with: openssl rand -hex 32
JWT_SECRET=your_super_secret_jwt_key_here_change_this_in_production_use_hex32_chars_minimum

# ==================== ADMIN CREDENTIALS ====================
# Use strong passwords! These are for development only.
# Hash passwords before storing in production.
ADMIN_USER1=AdminUser1
ADMIN_USER1_PASSWORD=Admin@U1_change_this_secure_password

ADMIN_USER2=AdminUser2
ADMIN_USER2_PASSWORD=Admin@U2_change_this_secure_password

# ==================== DATABASE ====================
DATABASE_PATH=login_data.db

# ==================== LOGGING ====================
LOG_LEVEL=INFO
LOG_FILE=server.log
DEBUG_MODE=false

# ==================== NETWORK ====================
# Set to false for production to prevent IP spoofing
ALLOW_ALL_IPS=true
SERVER_HOST=0.0.0.0
GAME_SERVER_PORT=8765
LOGIN_SERVER_PORT=8766

# ==================== GAME CONFIG ====================
MAX_PLAYERS=256
MAX_PLAYERS_PER_LOBBY=64
AUTO_SAVE_INTERVAL_MINUTES=2
