# ==================== ENUMS ====================
class GameState(Enum):
    CONNECTING = "connecting"
    LOGIN = "login"
    LOBBY = "lobby"
    PLAYING = "playing"
    DEAD = "dead"
    SPECTATING = "spectating"
    MENU = "menu"

class PlayerState(Enum):
    ALIVE = "alive"
    DEAD = "dead"
    SPECTATING = "spectating"

# ==================== HELPER CLASSES ====================
class Vector2:
    def __init__(self, x=0, y=0):
        self.x = x
        self.y = y
    
    def __add__(self, other):
        return Vector2(self.x + other.x, self.y + other.y)
    
    def __sub__(self, other):
        return Vector2(self.x - other.x, self.y - other.y)
    
    def __mul__(self, scalar):
        return Vector2(self.x * scalar, self.y * scalar)
    
    def distance_to(self, other):
        return math.sqrt((self.x - other.x)**2 + (self.y - other.y)**2)
    
    def normalize(self):
        length = math.sqrt(self.x**2 + self.y**2)
        if length > 0:
            return Vector2(self.x / length, self.y / length)
        return Vector2(0, 0)
    
    def angle(self):
        return math.atan2(self.y, self.x)

class InputManager:
    def __init__(self, config):
        self.config = config['keyboard']
        self.keys = {}
        self.mouse_pos = (0, 0)
        self.mouse_buttons = {}
        self.key_map = self._create_key_map()
    
    def _create_key_map(self):
        """Create mapping from config strings to pygame constants"""
        key_map = {
            'W': pygame.K_w, 'S': pygame.K_s, 'A': pygame.K_a, 'D': pygame.K_d,
            'Q': pygame.K_q, 'E': pygame.K_e, 'R': pygame.K_r, 'T': pygame.K_t,
            'Z': pygame.K_z, 'F': pygame.K_f, 'TAB': pygame.K_TAB,
            'SHIFT': pygame.K_LSHIFT, 'SPACE': pygame.K_SPACE
        }
        return key_map
    
    def update(self):
        """Update input state"""
        self.keys = pygame.key.get_pressed()
        self.mouse_pos = pygame.mouse.get_pos()
        self.mouse_buttons = pygame.mouse.get_pressed()
    
    def is_pressed(self, action):
        """Check if action key is pressed"""
        key_name = self.config.get(action)
        if not key_name:
            return False
        if key_name == 'MOUSE_LEFT':
            return self.mouse_buttons[0]
        key_const = self.key_map.get(key_name)
        return self.keys[key_const] if key_const else False
    
    def get_direction(self):
        """Get movement direction from WASD"""
        direction = Vector2(0, 0)
        if self.is_pressed('right'):
            direction.x += 1
        if self.is_pressed('left'):
            direction.x -= 1
        if self.is_pressed('down'):
            direction.y += 1
        if self.is_pressed('up'):
            direction.y -= 1
        return direction.normalize() if direction.x or direction.y else Vector2(0, 0)
    
    def get_mouse_angle(self):
        """Get angle from player to mouse"""
        return math.atan2(self.mouse_pos[1] - SCREEN_HEIGHT/2, 
                         self.mouse_pos[0] - SCREEN_WIDTH/2)

# ==================== GAME OBJECTS ====================
class RemotePlayer:
    def __init__(self, player_id, username, x, y, team, tank_name):
        self.id = player_id
        self.username = username
        self.x = x
        self.y = y
        self.angle = 0
        self.team = team
        self.tank_name = tank_name
        self.health = 100
        self.max_health = 100
        self.is_alive = True
        self.score = 0
        self.rank = 1
        self.last_update = time.time()
    
    def update(self, data):
        """Update from server data"""
        self.x = data.get('x', self.x)
        self.y = data.get('y', self.y)
        self.angle = data.get('angle', self.angle)
        self.health = data.get('health', self.health)
        self.max_health = data.get('max_health', self.max_health)
        self.is_alive = data.get('alive', True)
        self.score = data.get('score', self.score)
        self.rank = data.get('rank', self.rank)
        self.last_update = time.time()
    
    def draw(self, surface, camera_pos, player_team, tank_images):
        """Draw player on screen"""
        screen_x = self.x - camera_pos[0] + SCREEN_WIDTH/2
        screen_y = self.y - camera_pos[1] + SCREEN_HEIGHT/2
        
        # Skip if off-screen
        if screen_x < -100 or screen_x > SCREEN_WIDTH + 100 or \
           screen_y < -100 or screen_y > SCREEN_HEIGHT + 100:
            return
        
        # Draw health bar
        if not self.is_alive:
            return
        
        # Color based on team
        if self.team == player_team:
            color = tuple(CLIENT_CONFIG['colors']['player_teammate'])
        else:
            color = tuple(CLIENT_CONFIG['colors']['player_enemy'])
        
        # Draw tank
        radius = 15
        pygame.draw.circle(surface, color, (int(screen_x), int(screen_y)), radius)
        
        # Draw barrel
        barrel_length = 25
        barrel_x = screen_x + math.cos(self.angle) * barrel_length
        barrel_y = screen_y + math.sin(self.angle) * barrel_length
        pygame.draw.line(surface, color, (screen_x, screen_y), 
                        (barrel_x, barrel_y), 3)
        
        # Draw name and health
        if CLIENT_CONFIG['gameplay']['show_names']:
            name_text = font_tiny.render(self.username, True, (255, 255, 255))
            surface.blit(name_text, (screen_x - 20, screen_y - 30))
        
        if CLIENT_CONFIG['gameplay']['show_health_bars']:
            health_width = 40
            health_height = 5
            health_bar_rect = pygame.Rect(screen_x - health_width/2, screen_y + 20, 
                                         health_width * (self.health / self.max_health), health_height)
            pygame.draw.rect(surface, (100, 255, 100), health_bar_rect)
            pygame.draw.rect(surface, (255, 255, 255), 
                           pygame.Rect(screen_x - health_width/2, screen_y + 20, health_width, health_height), 1)

class Blob:
    def __init__(self, blob_id, x, y, blob_type, hp, reward):
        self.id = blob_id
        self.x = x
        self.y = y
        self.type = blob_type
        self.hp = hp
        self.max_hp = hp
        self.reward = reward
        self.radius = 8
    
    def update(self, data):
        """Update from server data"""
        self.x = data.get('x', self.x)
        self.y = data.get('y', self.y)
        self.hp = data.get('hp', self.hp)
    
    def draw(self, surface, camera_pos):
        """Draw blob on screen"""
        screen_x = self.x - camera_pos[0] + SCREEN_WIDTH/2
        screen_y = self.y - camera_pos[1] + SCREEN_HEIGHT/2
        
        if screen_x < -50 or screen_x > SCREEN_WIDTH + 50 or \
           screen_y < -50 or screen_y > SCREEN_HEIGHT + 50:
            return
        
        # Color based on type
        color_key = f'blob_{self.type}'
        color = tuple(CLIENT_CONFIG['colors'].get(color_key, [200, 200, 200]))
        
        # Draw blob shape
        if self.type == 'circle':
            pygame.draw.circle(surface, color, (int(screen_x), int(screen_y)), self.radius)
        elif self.type == 'triangle':
            points = [
                (screen_x, screen_y - self.radius),
                (screen_x + self.radius, screen_y + self.radius),
                (screen_x - self.radius, screen_y + self.radius)
            ]
            pygame.draw.polygon(surface, color, points)
        elif self.type == 'square':
            pygame.draw.rect(surface, color, 
                           (screen_x - self.radius, screen_y - self.radius, 
                            self.radius*2, self.radius*2))

class Bullet:
    def __init__(self, bullet_id, x, y, owner_id):
        self.id = bullet_id
        self.x = x
        self.y = y
        self.owner_id = owner_id
        self.radius = 3
        self.creation_time = time.time()
    
    def draw(self, surface, camera_pos):
        """Draw bullet on screen"""
        screen_x = self.x - camera_pos[0] + SCREEN_WIDTH/2
        screen_y = self.y - camera_pos[1] + SCREEN_HEIGHT/2
        
        if -50 < screen_x < SCREEN_WIDTH + 50 and -50 < screen_y < SCREEN_HEIGHT + 50:
            pygame.draw.circle(surface, (255, 255, 100), (int(screen_x), int(screen_y)), self.radius)

# ==================== MENU SYSTEM ====================
class Menu:
    def __init__(self, game_client):
        self.game_client = game_client
        self.active = False
        self.current_menu = "main"
        self.selected_option = 0
        self.options = {}
        self.init_menus()
    
    def init_menus(self):
        """Initialize menu structures"""
        self.options = {
            'main': [
                ('Resume (ESC)', self.resume),
                ('Tutorial', self.show_tutorial),
                ('Tank Upgrade (Q)', self.show_tank_upgrades),
                ('Skill Upgrade (E)', self.show_skill_upgrades),
                ('Tank Index', self.show_tank_index),
                ('Skill Index', self.show_skill_index),
                ('Rank Index', self.show_rank_index),
                ('Profile', self.show_profile),
                ('Settings', self.show_settings),
                ('Disconnect', self.disconnect),
                ('Quit Game', self.quit_game)
            ]
        }
    
    def toggle(self):
        """Toggle menu open/closed"""
        self.active = not self.active
        if self.active:
            self.current_menu = 'main'
            self.selected_option = 0
    
    def handle_input(self, input_manager):
        """Handle menu input"""
        if not self.active:
            return
        
        keys = pygame.key.get_pressed()
        if keys[pygame.K_UP]:
            self.selected_option = (self.selected_option - 1) % len(self.options[self.current_menu])
        if keys[pygame.K_DOWN]:
            self.selected_option = (self.selected_option + 1) % len(self.options[self.current_menu])
        if keys[pygame.K_RETURN]:
            option_name, option_func = self.options[self.current_menu][self.selected_option]
            option_func()
    
    def draw(self, surface):
        """Draw menu on screen"""
        if not self.active:
            return
        
        # Semi-transparent background
        overlay = pygame.Surface((SCREEN_WIDTH, SCREEN_HEIGHT))
        overlay.set_alpha(200)
        overlay.fill((0, 0, 0))
        surface.blit(overlay, (0, 0))
        
        # Menu title
        title = font_large.render(f"MENU - {self.current_menu.upper()}", True, (100, 255, 100))
        surface.blit(title, (SCREEN_WIDTH//2 - title.get_width()//2, 50))
        
        # Menu options
        y_offset = 150
        for i, (option_name, _) in enumerate(self.options[self.current_menu]):
            color = (100, 255, 100) if i == self.selected_option else (200, 200, 200)
            text = font_medium.render(option_name, True, color)
            surface.blit(text, (SCREEN_WIDTH//2 - text.get_width()//2, y_offset + i*50))
        
        # Instructions
        instructions = font_small.render("↑/↓ to navigate, ENTER to select, ESC to close", True, (150, 150, 150))
        surface.blit(instructions, (SCREEN_WIDTH//2 - instructions.get_width()//2, SCREEN_HEIGHT - 50))
    
    # Menu callbacks
    def resume(self):
        self.active = False
    
    def show_tutorial(self):
        pass  # Implement tutorial
    
    def show_tank_upgrades(self):
        pass  # Implement tank upgrade UI
    
    def show_skill_upgrades(self):
        self.SKILLS_UI.toggle()
    
    def show_tank_index(self):
        pass  # Implement tank index
    
    def show_skill_index(self):
        pass  # Implement skill index
    
    def show_rank_index(self):
        pass  # Implement rank index
    
    def show_profile(self):
        pass  # Implement profile view
    
    def show_settings(self):
        pass  # Implement settings
    
    def disconnect(self):
        self.game_client.disconnect()
    
    def quit_game(self):
        pygame.quit()
        sys.exit()

