# ==================== GAME RENDERER ====================
class Renderer:
    def __init__(self, screen_width, screen_height):
        self.screen_width = screen_width
        self.screen_height = screen_height
        self.grid_surface = None
        self.create_grid()
    
    def create_grid(self):
        """Create grid texture from grid.png"""
        try:
            grid_img = Image.open('grid.png')
            grid_img = grid_img.resize((self.screen_width, self.screen_height))
            self.grid_surface = pygame.image.fromstring(
                grid_img.tobytes(), grid_img.size, grid_img.mode
            )
        except FileNotFoundError:
            # Create procedural grid if image not found
            self.grid_surface = pygame.Surface((self.screen_width, self.screen_height))
            self.grid_surface.fill((20, 20, 20))
            grid_size = 50
            for x in range(0, self.screen_width, grid_size):
                pygame.draw.line(self.grid_surface, (60, 60, 60), (x, 0), (x, self.screen_height))
            for y in range(0, self.screen_height, grid_size):
                pygame.draw.line(self.grid_surface, (60, 60, 60), (0, y), (self.screen_width, y))
    
    def draw_world(self, surface, players, blobs, bullets, camera_pos, brightness):
        """Draw world with grid and coloring"""
        surface.fill((20, 20, 20))
        
        # Apply day/night coloring
        day_color = tuple(CLIENT_CONFIG['colors']['day_color'])
        night_color = tuple(CLIENT_CONFIG['colors']['night_color'])
        overlay = pygame.Surface((self.screen_width, self.screen_height))
        overlay.set_alpha(100)
        overlay.fill(tuple(int(day_color[i] * brightness + night_color[i] * (1-brightness)) 
                          for i in range(3)))
        surface.blit(overlay, (0, 0))
        
        # Draw grid
        if GRID_VISIBLE:
            grid_offset_x = -int(camera_pos[0]) % 50
            grid_offset_y = -int(camera_pos[1]) % 50
            surface.blit(self.grid_surface, (grid_offset_x, grid_offset_y))
        
        # Draw blobs
        for blob in blobs:
            blob.draw(surface, camera_pos)
        
        # Draw bullets
        for bullet in bullets:
            bullet.draw(surface, camera_pos)
        
        # Draw players
        for player in players:
            player.draw(surface, camera_pos, 1, {})  # TODO: pass tank images
    
    def draw_hud(self, surface, player, players, config):
        """Draw heads-up display"""
        if not player:
            return
        
        # Health bar
        health_width = 200
        health_x = 20
        health_y = 20
        health_ratio = player['health'] / player['max_health']
        
        pygame.draw.rect(surface, (100, 255, 100), 
                        (health_x, health_y, health_width * health_ratio, 20))
        pygame.draw.rect(surface, (255, 255, 255), 
                        (health_x, health_y, health_width, 20), 2)
        
        health_text = font_small.render(f"Health: {player['health']}/{player['max_health']}", 
                                        True, (255, 255, 255))
        surface.blit(health_text, (health_x + 5, health_y + 25))
        
        # Score and rank
        score_text = font_small.render(f"Score: {player['score']}", True, (100, 255, 100))
        surface.blit(score_text, (20, SCREEN_HEIGHT - 100))
        
        rank_text = font_small.render(f"Rank: {player['rank']}", True, (100, 255, 100))
        surface.blit(rank_text, (20, SCREEN_HEIGHT - 60))
        
        tank_text = font_small.render(f"Tank: {player['tank']}", True, (100, 100, 255))
        surface.blit(tank_text, (20, SCREEN_HEIGHT - 20))
        
        # Minimap
        self.draw_minimap(surface, player, players)
    
    def draw_minimap(self, surface, player, players):
        """Draw minimap in corner"""
        minimap_size = 150
        minimap_x = SCREEN_WIDTH - minimap_size - 10
        minimap_y = 10
        
        # Minimap background
        pygame.draw.rect(surface, (0, 0, 0), 
                        (minimap_x, minimap_y, minimap_size, minimap_size))
        pygame.draw.rect(surface, (100, 100, 100), 
                        (minimap_x, minimap_y, minimap_size, minimap_size), 2)
        
        # Draw players on minimap
        scale = minimap_size / 9280  # World width = 9280
        for p in players:
            mm_x = minimap_x + p['x'] * scale
            mm_y = minimap_y + p['y'] * scale
            
            if p['id'] == player['id']:
                pygame.draw.circle(surface, (100, 255, 100), (int(mm_x), int(mm_y)), 3)
            elif p['team'] == player['team']:
                pygame.draw.circle(surface, (100, 150, 255), (int(mm_x), int(mm_y)), 2)
            else:
                pygame.draw.circle(surface, (255, 100, 100), (int(mm_x), int(mm_y)), 2)

# ==================== WEBSOCKET CLIENT ====================
class GameClient:
    def __init__(self):
        self.game_ws = None
        self.login_ws = None
        self.token = None
        self.player_id = None
        self.player_data = None
        self.game_state = GameState.CONNECTING
        self.connected = False
        self.server_config = {}
        
        # Game data
        self.players = {}
        self.blobs = {}
        self.bullets = {}
        self.chat_messages = []
        
        # Buffers
        self.server_messages = asyncio.Queue()
        self.client_loop = None
    
    async def login(self, username: str, password: str) -> bool:
        """Authenticate with login server"""
        login_url = CLIENT_CONFIG['network']['login_server']
        
        try:
            async with websockets.connect(login_url) as ws:
                await ws.send(json.dumps({
                    'action': 'login',
                    'username': username,
                    'password': password
                }))
                
                response = json.loads(await ws.recv())
                
                if response.get('success'):
                    self.token = response['token']
                    self.player_data = {
                        'user_id': response['user_id'],
                        'username': response['username'],
                        'stats': response.get('stats', {})
                    }
                    return True
                return False
        except Exception as e:
            print(f"Login error: {e}")
            return False
    
    async def connect_to_game(self, username: str, team: int = 1) -> bool:
        """Connect to game server"""
        game_url = CLIENT_CONFIG['network']['game_server']
        
        try:
            self.game_ws = await websockets.connect(game_url)
            self.connected = True
            
            # Send auth
            await self.game_ws.send(json.dumps({
                'type': 'auth',
                'token': self.token,
                'username': username,
                'team': team
            }))
            
            # Receive welcome
            response = json.loads(await self.game_ws.recv())
            if response['type'] == 'welcome':
                self.player_id = response['player_id']
                self.server_config = response.get('config', {})
                self.game_state = GameState.LOBBY
                
                # Start message receiver
                asyncio.create_task(self._receive_messages())
                return True
            
            return False
        except Exception as e:
            print(f"Connection error: {e}")
            self.connected = False
            return False
    
    async def _receive_messages(self):
        """Receive and process server messages"""
        try:
            async for message in self.game_ws:
                data = json.loads(message)
                await self.server_messages.put(data)
        except websockets.exceptions.ConnectionClosed:
            self.connected = False
    
    def process_messages(self):
        """Process queued server messages (non-async)"""
        while not self.server_messages.empty():
            try:
                data = self.server_messages.get_nowait()
                self._handle_message(data)
            except asyncio.QueueEmpty:
                break
    
    def _handle_message(self, data: dict):
        """Handle server message"""
        msg_type = data.get('type')
        
        if msg_type == 'state':
            # Update game state
            for player_data in data.get('players', []):
                player_id = player_data['id']
                if player_id not in self.players:
                    self.players[player_id] = RemotePlayer(
                        player_id, player_data['username'], 
                        player_data['x'], player_data['y'],
                        player_data['team'], player_data['tank']
                    )
                else:
                    self.players[player_id].update(player_data)
            
            for blob_data in data.get('blobs', []):
                blob_id = blob_data['id']
                if blob_id not in self.blobs:
                    self.blobs[blob_id] = Blob(
                        blob_id, blob_data['x'], blob_data['y'],
                        blob_data['type'], blob_data['hp'], blob_data['reward']
                    )
                else:
                    self.blobs[blob_id].update(blob_data)
            
            for bullet_data in data.get('bullets', []):
                bullet_id = bullet_data['id']
                self.bullets[bullet_id] = Bullet(
                    bullet_id, bullet_data['x'], bullet_data['y'],
                    bullet_data['owner_id']
                )
        
        elif msg_type == 'player_joined':
            player_data = data['player']
            if player_data['id'] not in self.players:
                self.players[player_data['id']] = RemotePlayer(
                    player_data['id'], player_data['username'],
                    player_data['x'], player_data['y'],
                    player_data['team'], player_data['tank']
                )
        
        elif msg_type == 'player_left':
            player_id = data['player_id']
            if player_id in self.players:
                del self.players[player_id]
        
        elif msg_type == 'chat':
            self.chat_messages.append({
                'username': data['username'],
                'message': data['message'],
                'team': data['team']
            })
            if len(self.chat_messages) > 50:
                self.chat_messages.pop(0)
    
    async def send_move(self, vx: float, vy: float):
        """Send movement to server"""
        if self.game_ws and self.connected:
            await self.game_ws.send(json.dumps({
                'type': 'move',
                'vx': vx,
                'vy': vy
            }))
    
    async def send_shoot(self, angle: float):
        """Send shoot to server"""
        if self.game_ws and self.connected:
            await self.game_ws.send(json.dumps({
                'type': 'shoot',
                'angle': angle
            }))
    
    async def send_chat(self, message: str):
        """Send chat message"""
        if self.game_ws and self.connected:
            await self.game_ws.send(json.dumps({
                'type': 'chat',
                'message': message
            }))
    
    async def send_buy_tank(self, tank_name: str):
        """Buy tank"""
        if self.game_ws and self.connected:
            await self.game_ws.send(json.dumps({
                'type': 'buy_tank',
                'tank_name': tank_name
            }))
    
    async def send_buy_upgrade(self, upgrade_name: str):
        """Buy upgrade"""
        if self.game_ws and self.connected:
            await self.game_ws.send(json.dumps({
                'type': 'buy_upgrade',
                'upgrade_name': upgrade_name
            }))
    
    def disconnect(self):
        """Disconnect from server"""
        self.connected = False
        if self.game_ws:
            asyncio.create_task(self.game_ws.close())

# ==================== LOGIN SCREEN ====================
class LoginScreen:
    def __init__(self, game_client):
        self.game_client = game_client
        self.username_input = ""
        self.password_input = ""
        self.active_field = 0
        self.error_message = ""
        self.connecting = False
    
    def handle_input(self, event):
        """Handle login input"""
        if event.type == pygame.KEYDOWN:
            if event.key == pygame.K_TAB:
                self.active_field = 1 - self.active_field
            elif event.key == pygame.K_BACKSPACE:
                if self.active_field == 0:
                    self.username_input = self.username_input[:-1]
                else:
                    self.password_input = self.password_input[:-1]
            elif event.key == pygame.K_RETURN:
                asyncio.create_task(self._try_login())
            else:
                char = event.unicode
                if char.isalnum() or char in '-_.@':
                    if self.active_field == 0:
                        self.username_input += char
                    else:
                        self.password_input += char
    
    async def _try_login(self):
        """Attempt login"""
        self.connecting = True
        if await self.game_client.login(self.username_input, self.password_input):
            if await self.game_client.connect_to_game(self.username_input):
                self.error_message = ""
                return True
            else:
                self.error_message = "Failed to connect to game server"
        else:
            self.error_message = "Invalid credentials"
        self.connecting = False
        return False
    
    def draw(self, surface):
        """Draw login screen"""
        surface.fill((20, 20, 20))
        
        # Title
        title = font_large.render("TANK BATTLE ARENA", True, (100, 255, 100))
        surface.blit(title, (SCREEN_WIDTH//2 - title.get_width()//2, 50))
        
        # Username field
        username_text = font_medium.render("Username:", True, (200, 200, 200))
        surface.blit(username_text, (SCREEN_WIDTH//2 - 200, 200))
        
        username_input_color = (100, 255, 100) if self.active_field == 0 else (100, 100, 100)
        pygame.draw.rect(surface, username_input_color,
                        (SCREEN_WIDTH//2 - 200, 250, 300, 40), 2)
        username_render = font_medium.render(self.username_input or "Enter username", 
                                            True, username_input_color)
        surface.blit(username_render, (SCREEN_WIDTH//2 - 190, 255))
        
        # Password field
        password_text = font_medium.render("Password:", True, (200, 200, 200))
        surface.blit(password_text, (SCREEN_WIDTH//2 - 200, 320))
        
        password_input_color = (100, 255, 100) if self.active_field == 1 else (100, 100, 100)
        pygame.draw.rect(surface, password_input_color,
                        (SCREEN_WIDTH//2 - 200, 370, 300, 40), 2)
        password_render = font_medium.render("*" * len(self.password_input) or "Enter password",
                                            True, password_input_color)
        surface.blit(password_render, (SCREEN_WIDTH//2 - 190, 375))
        
        # Error message
        if self.error_message:
            error_text = font_small.render(self.error_message, True, (255, 100, 100))
            surface.blit(error_text, (SCREEN_WIDTH//2 - error_text.get_width()//2, 450))
        
        # Connecting status
        if self.connecting:
            connecting_text = font_small.render("Connecting...", True, (100, 100, 255))
            surface.blit(connecting_text, (SCREEN_WIDTH//2 - connecting_text.get_width()//2, 500))
        
        # Instructions
        instructions = font_tiny.render("TAB to switch fields, ENTER to login", True, (150, 150, 150))
        surface.blit(instructions, (SCREEN_WIDTH//2 - instructions.get_width()//2, SCREEN_HEIGHT - 50))

# ==================== MAIN GAME CLASS ====================
class Game:
    def __init__(self):
        self.game_client = GameClient()
        self.input_manager = InputManager(CLIENT_CONFIG)
        self.renderer = Renderer(SCREEN_WIDTH, SCREEN_HEIGHT)
        self.menu = Menu(self.game_client)
        self.login_screen = LoginScreen(self.game_client)
        self.game_state = GameState.LOGIN
        self.camera_pos = Vector2(0, 0)
        self.player_local = None
        self.running = True
        self.auto_shoot = CLIENT_CONFIG['gameplay']['auto_shoot_enabled']
        self.auto_spin = CLIENT_CONFIG['gameplay']['auto_spin_enabled']
        self.last_send_time = 0
        self.send_rate = CLIENT_CONFIG['network']['send_rate_ms'] / 1000
    
    def handle_events(self):
        """Handle pygame events"""
        for event in pygame.event.get():
            if event.type == pygame.QUIT:
                self.running = False
            
            elif event.type == pygame.KEYDOWN:
                # Menu toggle
                if event.key == pygame.K_z:
                    self.menu.toggle()

                # Skills UI
                elif event.key == pygame.K_e:
                    self.SKILLS_UI.toggle()
                
                # Auto-shoot toggle
                elif event.key == pygame.K_f:
                    self.auto_shoot = not self.auto_shoot
                
                # Auto-spin toggle
                elif event.key == pygame.K_r:
                    self.auto_spin = not self.auto_spin
                
                # Close menu
                elif event.key == pygame.K_ESCAPE:
                    if self.menu.active:
                        self.menu.active = False
                
                # Login screen input
                elif self.game_state == GameState.LOGIN:
                    self.login_screen.handle_input(event)
            
            # Menu input
            if self.game_state in [GameState.PLAYING, GameState.DEAD] and self.menu.active:
                self.menu.handle_input(self.input_manager)
    
    def update(self):
        """Update game logic"""
        self.input_manager.update()
        self.game_client.process_messages()
        
        if self.game_state == GameState.PLAYING:
            self._update_gameplay()
        
        self.menu.handle_input(self.input_manager)
    
    def _update_gameplay(self):
        """Update gameplay"""
        if self.player_id not in self.game_client.players:
            return
        
        self.player_local = self.game_client.players[self.player_id].to_dict() if hasattr(
            self.game_client.players[self.player_id], 'to_dict') else None
        
        # Get movement input
        direction = self.input_manager.get_direction()
        angle = self.input_manager.get_mouse_angle()
        
        # Send movement
        current_time = time.time()
        if current_time - self.last_send_time > self.send_rate:
            asyncio.create_task(
                self.game_client.send_move(direction.x, direction.y)
            )
            self.last_send_time = current_time
        
        # Auto-shoot
        if self.auto_shoot:
            asyncio.create_task(self.game_client.send_shoot(angle))
        elif self.input_manager.is_pressed('shoot'):
            asyncio.create_task(self.game_client.send_shoot(angle))
        
        # Auto-spin
        if self.auto_spin:
            spin_angle = math.sin(time.time() * 2) * math.pi
            asyncio.create_task(self.game_client.send_shoot(spin_angle))
        
        # Update camera
        if self.player_local:
            target_x = self.player_local['x']
            target_y = self.player_local['y']
            
            smoothing = CLIENT_CONFIG['gameplay']['camera_smoothing']
            self.camera_pos.x += (target_x - self.camera_pos.x) * smoothing
            self.camera_pos.y += (target_y - self.camera_pos.y) * smoothing
    
    def draw(self):
        """Draw game"""
        if self.game_state == GameState.LOGIN:
            self.login_screen.draw(screen)
        
        elif self.game_state in [GameState.PLAYING, GameState.DEAD, GameState.SPECTATING]:
            # Get day/night info from server
            brightness = 1.0
            
            # Draw world
            player_list = list(self.game_client.players.values())
            blob_list = list(self.game_client.blobs.values())
            bullet_list = list(self.game_client.bullets.values())
            
            self.renderer.draw_world(screen, player_list, blob_list, bullet_list,
                                    (self.camera_pos.x, self.camera_pos.y), brightness)
            
            # Draw HUD
            if self.player_local:
                self.renderer.draw_hud(screen, self.player_local, 
                                      [p.to_dict() if hasattr(p, 'to_dict') else p 
                                       for p in player_list], CLIENT_CONFIG)
            
            # Draw chat
            self._draw_chat()
            
            # Draw auto-shoot/spin status
            if self.auto_shoot:
                auto_shoot_text = font_tiny.render("AUTO-SHOOT: ON (F)", True, (100, 255, 100))
                screen.blit(auto_shoot_text, (SCREEN_WIDTH - 250, SCREEN_HEIGHT - 100))
            
            if self.auto_spin:
                auto_spin_text = font_tiny.render("AUTO-SPIN: ON (R)", True, (100, 255, 100))
                screen.blit(auto_spin_text, (SCREEN_WIDTH - 250, SCREEN_HEIGHT - 70))
        
        # Draw menu
        self.menu.draw(screen)
        
        pygame.display.flip()
    
    def _draw_chat(self):
        """Draw chat messages"""
        y_offset = 20
        for msg in self.game_client.chat_messages[-5:]:
            text = f"{msg['username']}: {msg['message']}"
            chat_text = font_tiny.render(text, True, (200, 200, 200))
            screen.blit(chat_text, (20, y_offset))
            y_offset += 20
    
    def run(self):
        """Main game loop"""
        while self.running:
            self.handle_events()
            self.update()
            self.draw()
            clock.tick(FPS)
        
        pygame.quit()

# ==================== MAIN ====================
def main():
    game = Game()
    game.run()

if __name__ == "__main__":
    main()
