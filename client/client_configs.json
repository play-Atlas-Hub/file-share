  "colors": {
    "player_self": [100, 255, 100],
    "player_teammate": [100, 150, 255],
    "player_enemy": [255, 100, 100],
    "blob_circle": [200, 200, 200],
    "blob_triangle": [220, 150, 150],
    "blob_square": [150, 220, 150],
    "grid_color": [60, 60, 60],
    "day_color": [255, 255, 200],
    "night_color": [100, 100, 150]
