{
  "display": {
    "width": 1280,
    "height": 720,
    "fullscreen": false,
    "fps": 60,
    "grid_visible": true,
    "minimap_scale": 0.15,
    "minimap_position": "top-right"
  },
  "keyboard": {
    "up": "W",
    "down": "S",
    "left": "A",
    "right": "D",
    "shoot": "MOUSE_LEFT",
    "auto_shoot": "F",
    "auto_spin": "R",
    "menu": "Z",
    "upgrade_skills": "E",
    "upgrade_tank": "Q",
    "chat": "T",
    "spectate_next": "TAB",
    "spectate_prev": "SHIFT+TAB",
    "zoom_in": "SCROLL_UP",
    "zoom_out": "SCROLL_DOWN"
  },
  "gameplay": {
    "auto_shoot_enabled": true,
    "auto_spin_enabled": true,
    "show_names": true,
    "show_health_bars": true,
    "show_damage_numbers": true,
